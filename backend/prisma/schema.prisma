generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  locked
  disabled
  pending
}

enum OrganizationStatus {
  active
  suspended
  deleted
}

enum OrganizationMemberStatus {
  active
  invited
  removed
}

enum ProjectStatus {
  active
  paused
  archived
}

enum ProjectEnvironment {
  production
  preview
  development
}

enum DeploymentEnvironment {
  production
  preview
}

enum DeploymentStatus {
  queued
  building
  uploading
  deployed
  failed
  cancelled
  rolled_back
}

enum DeploymentSource {
  git
  builder
  manual
}

enum DeploymentLogLevel {
  info
  warn
  error
  debug
}

enum ArtifactStatus {
  uploading
  ready
  deleted
}

enum WebhookEventStatus {
  received
  processed
  failed
  ignored
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
  dead
}

enum NotificationChannel {
  email
  in_app
}

enum DomainStatus {
  pending_verification
  verified
  active
  misconfigured
  disabled
}

enum DnsRecordType {
  A
  AAAA
  CNAME
  TXT
  MX
  NS
  SRV
  CAA
}

enum DnsRecordStatus {
  pending
  active
  failed
}

enum SslCertificateStatus {
  pending
  issued
  active
  renewing
  expired
  failed
}

enum BuilderSiteStatus {
  draft
  published
  archived
}

enum BuilderPageStatus {
  draft
  published
  archived
}

enum AssetVisibility {
  public
  private
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  unpaid
  paused
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}


model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  name            String?
  avatarUrl       String?    @map("avatar_url")
  passwordHash    String?    @map("password_hash")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  status          UserStatus @default(pending)
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  apiKeys                    ApiKey[]                     @relation("ApiKeyUser")
  assetsUploaded             Asset[]                      @relation("AssetUploader")
  auditLogs                  AuditLog[]                   @relation("AuditActor")
  builderPageVersionsCreated BuilderPageVersion[]         @relation("BuilderPageVersionCreator")
  builderSitesCreated        BuilderSite[]                @relation("BuilderSiteCreator")
  createdOrganizations       Organization[]               @relation("OrganizationCreator")
  invitedMemberships         OrganizationMember[]         @relation("InvitedMemberships")
  memberships                OrganizationMember[]         @relation("UserMemberships")
  notificationPreferences    NotificationPreference[]
  notifications              Notification[]
  oauthAccounts              OauthAccount[]
  projectsCreated            Project[]                    @relation("ProjectCreator")
  deploymentsTriggered       Deployment[]                 @relation("DeploymentTrigger")
  domainsCreated             Domain[]                     @relation("DomainCreator")
  sessions                   Session[]
  userActivityLogs           ActivityLog[]                @relation("ActivityActor")
  ProjectEnvironmentVariable ProjectEnvironmentVariable[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceLabel      String?   @map("device_label")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId])
  @@map("sessions")
}

model OauthAccount {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  provider              String
  providerUserId        String   @map("provider_user_id")
  accessTokenEncrypted  String?  @map("access_token_encrypted")
  refreshTokenEncrypted String?  @map("refresh_token_encrypted")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model ApiKey {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  name           String
  keyHash        String    @map("key_hash")
  prefix         String
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  scopes         Json      @default("[]")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("ApiKeyUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([prefix])
  @@index([userId])
  @@map("api_keys")
}

model Organization {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  slug             String             @unique
  billingEmail     String?            @map("billing_email")
  stripeCustomerId String?            @unique @map("stripe_customer_id")
  status           OrganizationStatus @default(active)
  createdByUserId  String?            @map("created_by_user_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  activityLogs               ActivityLog[]
  invitesSent                OrganizationInvite[]         @relation("OrganizationInvites")
  apiKeys                    ApiKey[]
  artifacts                  Artifact[]
  assets                     Asset[]
  auditLogs                  AuditLog[]
  billingInvoices            BillingInvoice[]
  billingUsageRecords        BillingUsageRecord[]
  builderPageVersions        BuilderPageVersion[]
  builderPages               BuilderPage[]
  builderSites               BuilderSite[]
  createdBy                  User?                        @relation("OrganizationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deploymentAliases          DeploymentAlias[]
  deployments                Deployment[]
  deploymentLogs             DeploymentLog[]
  domains                    Domain[]
  dnsRecords                 DnsRecord[]
  members                    OrganizationMember[]
  notificationPreferences    NotificationPreference[]
  notifications              Notification[]
  outgoingWebhookDeliveries  OutgoingWebhookDelivery[]
  outgoingWebhookEndpoints   OutgoingWebhookEndpoint[]
  projects                   Project[]
  roles                      Role[]
  sslCertificates            SslCertificate[]
  subscriptions              BillingSubscription[]
  webhookEvents              WebhookEvent[]
  ProjectEnvironmentVariable ProjectEnvironmentVariable[]

  @@index([createdByUserId])
  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id              String                   @id @default(uuid()) @db.Uuid
  organizationId  String                   @map("organization_id") @db.Uuid
  userId          String                   @map("user_id") @db.Uuid
  roleId          String                   @map("role_id") @db.Uuid
  status          OrganizationMemberStatus @default(invited)
  invitedByUserId String?                  @map("invited_by_user_id") @db.Uuid
  joinedAt        DateTime?                @map("joined_at")
  removedAt       DateTime?                @map("removed_at")
  createdAt       DateTime                 @default(now()) @map("created_at")

  invitedBy    User?        @relation("InvitedMemberships", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  user         User         @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([invitedByUserId])
  @@index([roleId])
  @@index([status])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationInvite {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  invitedByUserId   String    @map("invited_by_user_id") @db.Uuid
  acceptedByUserId  String?   @map("accepted_by_user_id") @db.Uuid
  email             String
  roleKey           String    @map("role_key")
  token             String    @unique
  expiresAt         DateTime  @map("expires_at")
  acceptedAt        DateTime? @map("accepted_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  organization Organization @relation("OrganizationInvites", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email, organizationId])
  @@index([organizationId])
  @@index([token])
  @@map("organization_invites")
}

model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  name           String
  key            String
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")

  members         OrganizationMember[]
  organization    Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([organizationId, key])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  name        String
  description String?
  module      String

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Project {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @map("organization_id") @db.Uuid
  name               String
  slug               String
  framework          String?
  repositoryProvider String?       @map("repository_provider")
  repositoryOwner    String?       @map("repository_owner")
  repositoryName     String?       @map("repository_name")
  repositoryId       String?       @map("repository_id")
  renderServiceId    String?       @map("render_service_id")
  productionBranch   String?       @default("main") @map("production_branch")
  rootDirectory      String?       @map("root_directory")
  buildCommand       String?       @map("build_command")
  outputDirectory    String?       @map("output_directory")
  installCommand     String?       @map("install_command")
  status             ProjectStatus @default(active)
  createdByUserId    String?       @map("created_by_user_id") @db.Uuid
  deletedAt          DateTime?     @map("deleted_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  createdBy         User?                        @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  aliases           DeploymentAlias[]
  artifacts         Artifact[]
  deployments       Deployment[]
  domains           Domain[]
  envVars           ProjectEnvironmentVariable[]
  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("projects")
}

model ProjectEnvironmentVariable {
  id              String             @id @default(uuid()) @db.Uuid
  projectId       String             @map("project_id") @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  key             String
  valueEncrypted  String             @map("value_encrypted")
  environment     ProjectEnvironment
  createdByUserId String?            @map("created_by_user_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  createdBy    User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key, environment])
  @@index([createdByUserId])
  @@index([organizationId, environment])
  @@index([projectId])
  @@map("project_environment_variables")
}

model Domain {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  projectId         String?      @map("project_id") @db.Uuid
  hostname          String
  rootDomain        String       @map("root_domain")
  status            DomainStatus @default(pending_verification)
  verificationToken String       @map("verification_token")
  verifiedAt        DateTime?    @map("verified_at")
  createdByUserId   String?      @map("created_by_user_id") @db.Uuid
  deletedAt         DateTime?    @map("deleted_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  aliases          DeploymentAlias[]
  createdBy        User?            @relation("DomainCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  dnsRecords       DnsRecord[]
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sslCertificates  SslCertificate[]

  @@unique([organizationId, hostname])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@index([projectId])
  @@map("domains")
}

model DnsRecord {
  id               String          @id @default(uuid()) @db.Uuid
  organizationId   String          @map("organization_id") @db.Uuid
  domainId         String          @map("domain_id") @db.Uuid
  type             DnsRecordType
  name             String
  value            String
  ttl              Int             @default(3600)
  priority         Int?
  proxied          Boolean         @default(false)
  providerRecordId String?         @map("provider_record_id")
  status           DnsRecordStatus @default(pending)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  domain       Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@index([organizationId])
  @@index([status])
  @@map("dns_records")
}

model SslCertificate {
  id            String               @id @default(uuid()) @db.Uuid
  domainId      String               @map("domain_id") @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  status        SslCertificateStatus @default(pending)
  provider      String
  certificateRef String?             @map("certificate_ref")
  issuedAt      DateTime?            @map("issued_at")
  expiresAt     DateTime?            @map("expires_at")
  lastCheckedAt DateTime?            @map("last_checked_at")
  errorMessage  String?              @map("error_message")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  domain       Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([domainId, status])
  @@index([expiresAt])
  @@index([organizationId])
  @@map("ssl_certificates")
}

model BuilderSite {
  id              String            @id @default(uuid()) @db.Uuid
  organizationId  String            @map("organization_id") @db.Uuid
  projectId       String?           @map("project_id") @db.Uuid
  name            String
  slug            String
  templateId      String?           @map("template_id") @db.Uuid
  status          BuilderSiteStatus @default(draft)
  publishedAt     DateTime?         @map("published_at")
  createdByUserId String?           @map("created_by_user_id") @db.Uuid
  deletedAt       DateTime?         @map("deleted_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  createdBy    User?         @relation("BuilderSiteCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages        BuilderPage[]
  template     Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([organizationId, slug])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@map("builder_sites")
}

model BuilderPage {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  siteId         String            @map("site_id") @db.Uuid
  path           String
  title          String
  content        Json              @default("{}")
  seoTitle       String?           @map("seo_title")
  seoDescription String?           @map("seo_description")
  status         BuilderPageStatus @default(draft)
  sortOrder      Int               @default(0) @map("sort_order")
  deletedAt      DateTime?         @map("deleted_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site         BuilderSite          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  versions     BuilderPageVersion[]

  @@unique([siteId, path])
  @@index([organizationId])
  @@index([siteId, status])
  @@map("builder_pages")
}

model BuilderPageVersion {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  siteId          String    @map("site_id") @db.Uuid
  pageId          String    @map("page_id") @db.Uuid
  versionNumber   Int       @map("version_number")
  contentJson     Json      @map("content_json")
  label           String?
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  createdBy    User?        @relation("BuilderPageVersionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  page         BuilderPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, versionNumber])
  @@index([organizationId])
  @@index([pageId, publishedAt])
  @@map("builder_page_versions")
}

model Template {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  category        String
  previewImageUrl String?  @map("preview_image_url")
  contentJson     Json     @map("content_json")
  isPublic        Boolean  @default(true) @map("is_public")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  sites BuilderSite[]

  @@index([category])
  @@index([isPublic])
  @@index([isActive, sortOrder])
  @@map("templates")
}

model BillingPlan {
  id                String   @id @default(uuid()) @db.Uuid
  key               String   @unique
  name              String
  description       String?
  priceMonthlyCents Int      @default(0) @map("price_monthly_cents")
  priceYearlyCents  Int      @default(0) @map("price_yearly_cents")
  currency          String   @default("USD")
  limits            Json     @default("{}")
  features          Json     @default("{}")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subscriptions BillingSubscription[]

  @@index([isActive])
  @@map("billing_plans")
}

model BillingSubscription {
  id                     String             @id @default(uuid()) @db.Uuid
  organizationId         String             @map("organization_id") @db.Uuid
  planId                 String             @map("plan_id") @db.Uuid
  provider               String             @default("stripe")
  status                 SubscriptionStatus @default(active)
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  providerCustomerId     String?            @map("provider_customer_id")
  providerSubscriptionId String?            @unique @map("provider_subscription_id")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  invoices     BillingInvoice[]
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         BillingPlan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  usageRecords BillingUsageRecord[]

  @@index([organizationId, status])
  @@index([planId])
  @@map("billing_subscriptions")
}

model BillingInvoice {
  id                String        @id @default(uuid()) @db.Uuid
  organizationId    String        @map("organization_id") @db.Uuid
  subscriptionId    String?       @map("subscription_id") @db.Uuid
  providerInvoiceId String?       @unique @map("provider_invoice_id")
  status            InvoiceStatus @default(open)
  currency          String        @default("USD")
  amountDueCents    Int           @default(0) @map("amount_due_cents")
  amountPaidCents   Int           @default(0) @map("amount_paid_cents")
  description       String?
  periodStart       DateTime?     @map("period_start")
  periodEnd         DateTime?     @map("period_end")
  issuedAt          DateTime?     @map("issued_at")
  paidAt            DateTime?     @map("paid_at")
  hostedInvoiceUrl  String?       @map("hosted_invoice_url")
  createdAt         DateTime      @default(now()) @map("created_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([subscriptionId])
  @@map("billing_invoices")
}

model BillingUsageRecord {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  subscriptionId String?  @map("subscription_id") @db.Uuid
  metricKey      String   @map("metric_key")
  quantity       Int      @default(0)
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId, metricKey, periodStart])
  @@index([projectId])
  @@index([subscriptionId])
  @@map("billing_usage_records")
}

model Deployment {
  id                String                @id @default(uuid()) @db.Uuid
  organizationId    String                @map("organization_id") @db.Uuid
  projectId         String                @map("project_id") @db.Uuid
  environment       DeploymentEnvironment
  status            DeploymentStatus      @default(queued)
  source            DeploymentSource
  provider          String?
  providerServiceId String?               @map("provider_service_id")
  providerDeployId  String?               @map("provider_deploy_id")
  providerStatus    String?               @map("provider_status")
  commitSha         String?               @map("commit_sha")
  commitMessage     String?               @map("commit_message")
  branch            String?
  triggeredByUserId String?               @map("triggered_by_user_id") @db.Uuid
  artifactId        String?               @map("artifact_id") @db.Uuid
  startedAt         DateTime?             @map("started_at")
  finishedAt        DateTime?             @map("finished_at")
  durationMs        Int?                  @map("duration_ms")
  errorCode         String?               @map("error_code")
  errorMessage      String?               @map("error_message")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  aliases         DeploymentAlias[]
  artifacts       Artifact[]
  logs            DeploymentLog[]
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredByUser User?           @relation("DeploymentTrigger", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([provider, providerDeployId])
  @@index([projectId, createdAt])
  @@index([triggeredByUserId])
  @@map("deployments")
}

model DeploymentLog {
  id             String             @id @default(uuid()) @db.Uuid
  deploymentId   String             @map("deployment_id") @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  sequence       Int
  level          DeploymentLogLevel
  message        String
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")

  deployment   Deployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([deploymentId, sequence])
  @@index([organizationId, createdAt])
  @@map("deployment_logs")
}

model DeploymentAlias {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  deploymentId   String   @map("deployment_id") @db.Uuid
  domainId       String?  @map("domain_id") @db.Uuid
  hostname       String
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")

  deployment   Deployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  domain       Domain?      @relation(fields: [domainId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([hostname])
  @@index([deploymentId])
  @@index([domainId])
  @@index([organizationId])
  @@index([projectId, isPrimary])
  @@map("deployment_aliases")
}

model Artifact {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  projectId      String         @map("project_id") @db.Uuid
  deploymentId   String?        @map("deployment_id") @db.Uuid
  bucket         String
  objectKey      String         @map("object_key")
  sizeBytes      Int            @default(0) @map("size_bytes")
  checksum       String?
  status         ArtifactStatus @default(uploading)
  createdAt      DateTime       @default(now()) @map("created_at")

  deployment   Deployment?  @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@map("artifacts")
}

model Asset {
  id               String          @id @default(uuid()) @db.Uuid
  organizationId   String          @map("organization_id") @db.Uuid
  uploadedByUserId String?         @map("uploaded_by_user_id") @db.Uuid
  bucket           String
  objectKey        String          @map("object_key")
  publicUrl        String?         @map("public_url")
  mimeType         String          @map("mime_type")
  sizeBytes        Int             @default(0) @map("size_bytes")
  checksum         String?
  visibility       AssetVisibility @default(private)
  metadata         Json            @default("{}")
  deletedAt        DateTime?       @map("deleted_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation("AssetUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, visibility])
  @@index([uploadedByUserId])
  @@map("assets")
}

model ActivityLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  action         String
  message        String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  actor        User?        @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([organizationId, createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model WebhookEvent {
  id              String             @id @default(uuid()) @db.Uuid
  organizationId  String?            @map("organization_id") @db.Uuid
  provider        String
  eventType       String             @map("event_type")
  externalEventId String             @map("external_event_id")
  payload         Json               @default("{}")
  status          WebhookEventStatus @default(received)
  processedAt     DateTime?          @map("processed_at")
  errorMessage    String?            @map("error_message")
  createdAt       DateTime           @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([organizationId])
  @@index([provider, status])
  @@map("webhook_events")
}

model OutgoingWebhookEndpoint {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  url             String
  events          String[]
  secret          String?
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  deliveries   OutgoingWebhookDelivery[]
  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@map("outgoing_webhook_endpoints")
}

model OutgoingWebhookDelivery {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  endpointId     String                @map("endpoint_id") @db.Uuid
  endpointUrl    String                @map("endpoint_url")
  eventType      String                @map("event_type")
  payload        Json                  @default("{}")
  status         WebhookDeliveryStatus @default(pending)
  statusCode     Int?                  @map("status_code")
  responseBody   String?               @map("response_body")
  errorMessage   String?               @map("error_message")
  attemptCount   Int                   @default(0) @map("attempt_count")
  deliveredAt    DateTime?             @map("delivered_at")
  nextAttemptAt  DateTime?             @map("next_attempt_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  endpoint     OutgoingWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([organizationId, status])
  @@index([nextAttemptAt])
  @@map("outgoing_webhook_deliveries")
}

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  type           String
  title          String
  body           String?
  actionUrl      String?   @map("action_url")
  readAt         DateTime? @map("read_at")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  eventType      String    @map("event_type")
  channel        String
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, eventType, channel])
  @@index([userId, organizationId])
  @@map("notification_preferences")
}
