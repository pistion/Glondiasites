NODE_ENV=development
APP_NAME=glondia-backend
APP_PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000/api/v1

DATABASE_URL=postgresql://glondia:glondia_password@localhost:5432/glondia
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFY_TOKEN_TTL_HOURS=24

FIELD_ENCRYPTION_KEY=base64_key_here

STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio_password
S3_ASSETS_BUCKET=glondia-assets
S3_ARTIFACTS_BUCKET=glondia-artifacts
S3_PUBLIC_BASE_URL=http://localhost:9000/glondia-assets

EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@glondia.app
RESEND_API_KEY=change_me

BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=change_me
STRIPE_WEBHOOK_SECRET=change_me
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_TEAM_MONTHLY=price_xxx

# Render hosting provider
RENDER_API_KEY=your_render_api_key_here
RENDER_API_BASE_URL=https://api.render.com/v1

GITHUB_CLIENT_ID=change_me
GITHUB_CLIENT_SECRET=change_me
GITHUB_WEBHOOK_SECRET=change_me

DNS_PROVIDER=manual
CLOUDFLARE_API_TOKEN=optional
ACME_DIRECTORY_URL=optional
ACME_ACCOUNT_EMAIL=admin@glondia.app

# Spaceship registrar integration
SPACESHIP_API_KEY=your_spaceship_api_key_here
SPACESHIP_API_SECRET=your_spaceship_api_secret_here
SPACESHIP_DEFAULT_CONTACT_ID=your_spaceship_contact_id_here

SENTRY_DSN=optional
OTEL_EXPORTER_OTLP_ENDPOINT=optional
LOG_LEVEL=info

RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=300
RATE_LIMIT_DEPLOYMENTS_PER_HOUR=20

BUILD_TIMEOUT_SECONDS=600
BUILD_MAX_CONCURRENT=2
BUILD_TEMP_DIR=/tmp/glondia-builds
